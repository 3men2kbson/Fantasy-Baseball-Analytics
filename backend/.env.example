# ─── Yahoo Developer App Credentials ─────────────────────────────────────────
# Obtén estas en: https://developer.yahoo.com/apps/create/
#
# 1. Ve a developer.yahoo.com/apps/create
# 2. Application Name: "Fantasy Baseball Analytics"  (o el nombre que quieras)
# 3. Description: "Personal fantasy baseball analytics dashboard"
# 4. Homepage URL: http://localhost:5173
# 5. En "API Permissions":
#      ✅  Fantasy Sports  →  Read
# 6. Callback Domain: localhost
# 7. Callback URL: http://localhost:8000/auth/callback
# 8. Haz click en "Create App"
# 9. Copia tu Client ID y Client Secret aquí:

YAHOO_CLIENT_ID=PEGA_TU_CLIENT_ID_AQUI
YAHOO_CLIENT_SECRET=PEGA_TU_CLIENT_SECRET_AQUI

# ─── Redirect URI (no cambies a menos que uses otro puerto) ──────────────────
YAHOO_REDIRECT_URI=http://localhost:8000/auth/callback

# ─── (Opcional) Para producción ──────────────────────────────────────────────
# YAHOO_REDIRECT_URI=https://tu-dominio.com/auth/callback
